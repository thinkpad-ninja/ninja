#!/usr/bin/env python3
"""commit — end-to-end ambient-media pipeline.

Stages (run in order):
  1. parts     trash any *.part file (aborted yt-dlp partial downloads).
  2. convert   each .webm  ->  .mp3 (audio-only, -b:a BITRATE), skipping ones
               that already have a valid .mp3; writes to .tmp then atomic-renames.
  3. cap       each .mp3 longer than LIMIT is trimmed in-place via ffmpeg
               stream-copy (fast, lossless); the full-length original is sent
               to trash.
  4. rename    normalize names: drop trailing [youtube-id], strip emojis and
               digits, lowercase, keep only letters, join words up to a char
               cap with underscores. Pairs rename together.
  5. cleanup   .webm files whose .mp3 sibling exists and is verified valid
               are sent to trash (freeing the big source files).

Safety:
  - Dry-run by default. --yes is required to mutate anything.
  - Destroyed files go to the XDG trash via trash-put (recoverable from your
    file manager). Pass --hard for permanent rm.
  - Any directory named 'mp4' is never entered.

Usage:
  ./commit                       # preview everything
  ./commit --yes                 # run full pipeline
  ./commit --yes --hard          # run full pipeline, permanent rm
  ./commit --skip-rename --yes   # opt out of a stage
  ./commit /other/path --yes
"""

from __future__ import annotations

import argparse
import re
import shutil
import subprocess
import sys
import unicodedata
from pathlib import Path

DEFAULT_BITRATE = "128k"
DEFAULT_LIMIT_SEC = 3600
DEFAULT_MAX_CHARS = 12
DEFAULT_RENAME_EXTS = "mp3,webm"
EXCLUDE_DIRS = {"mp4"}


# ---------- helpers ----------

def human(n: float) -> str:
    for unit in ("B", "K", "M", "G", "T"):
        if abs(n) < 1024:
            return f"{n:.1f}{unit}"
        n /= 1024
    return f"{n:.1f}P"


def hms(sec: int) -> str:
    return f"{sec // 3600}h{(sec % 3600) // 60:02d}m{sec % 60:02d}s"


def iter_files(root: Path, exts: set[str]):
    for path in sorted(root.rglob("*")):
        try:
            rel = path.relative_to(root)
        except ValueError:
            continue
        if any(part in EXCLUDE_DIRS for part in rel.parts):
            continue
        if not path.is_file():
            continue
        if path.suffix.lstrip(".").lower() in exts:
            yield path


def ffprobe_audio_ok(p: Path) -> bool:
    r = subprocess.run(
        ["ffprobe", "-v", "error", "-select_streams", "a",
         "-show_entries", "stream=codec_type", "-of", "csv=p=0", str(p)],
        capture_output=True, text=True,
    )
    return r.returncode == 0 and "audio" in r.stdout


def ffprobe_duration(p: Path) -> int | None:
    r = subprocess.run(
        ["ffprobe", "-v", "error", "-show_entries", "format=duration",
         "-of", "default=nk=1:nw=1", str(p)],
        capture_output=True, text=True,
    )
    if r.returncode != 0 or not r.stdout.strip():
        return None
    try:
        return int(float(r.stdout.strip()))
    except ValueError:
        return None


def discard(path: Path, hard: bool) -> None:
    if hard:
        path.unlink()
    else:
        subprocess.run(["trash-put", "--", str(path)], check=True)


# ---------- stage 1: parts ----------

def stage_parts(root: Path, dry: bool, hard: bool) -> int:
    print("=" * 60)
    print("STAGE 1: trash *.part (partial downloads)")
    print("=" * 60)
    gone = failed = 0
    freed = 0
    for part in iter_files(root, {"part"}):
        sz = part.stat().st_size
        if dry:
            gone += 1
            freed += sz
            print(f"WOULD TRASH  {human(sz)}  {part.name}")
            continue
        try:
            discard(part, hard)
            gone += 1
            freed += sz
            print(f"{'DEL' if hard else 'TRASH'}  {human(sz)}  {part.name}")
        except subprocess.CalledProcessError as e:
            failed += 1
            print(f"FAIL  {part.name}: {e}", file=sys.stderr)
    verb = "would free" if dry else "freed"
    print(f"\n{'would-trash' if dry else 'trashed'}: {gone}  failed: {failed}  {verb}: {human(freed)}\n")
    return failed


# ---------- stage 2: convert ----------

def stage_convert(root: Path, bitrate: str, dry: bool) -> int:
    print("=" * 60)
    print("STAGE 2: convert .webm -> .mp3")
    print("=" * 60)
    ok = skipped = failed = 0
    for webm in iter_files(root, {"webm"}):
        mp3 = webm.with_suffix(".mp3")
        if mp3.exists():
            skipped += 1
            continue
        if dry:
            print(f"WOULD CONV  {webm}")
            ok += 1
            continue
        tmp = mp3.with_suffix(".mp3.tmp")
        print(f"CONV        {webm}")
        r = subprocess.run(
            ["ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error",
             "-i", str(webm), "-vn", "-c:a", "libmp3lame", "-b:a", bitrate,
             "-f", "mp3", "-y", str(tmp)],
        )
        valid = (
            r.returncode == 0
            and tmp.exists()
            and tmp.stat().st_size > 0
            and ffprobe_audio_ok(tmp)
        )
        if valid:
            tmp.rename(mp3)
            ok += 1
        else:
            if tmp.exists():
                tmp.unlink()
            failed += 1
            print("  FAIL")
    print(f"\nconverted: {ok}  skipped: {skipped}  failed: {failed}\n")
    return failed


# ---------- stage 3: cap ----------

def stage_cap(root: Path, limit: int, dry: bool, hard: bool) -> int:
    print("=" * 60)
    print(f"STAGE 3: cap .mp3 to {hms(limit)}")
    print("=" * 60)
    cut = short = failed = 0
    bytes_in = bytes_out = 0
    for mp3 in iter_files(root, {"mp3"}):
        dur = ffprobe_duration(mp3)
        if dur is None:
            failed += 1
            print(f"FAIL  (ffprobe)  {mp3}")
            continue
        if dur <= limit:
            short += 1
            continue
        in_sz = mp3.stat().st_size
        if dry:
            est_out = in_sz * limit // dur
            bytes_in += in_sz
            bytes_out += est_out
            print(f"WOULD CAP   {hms(dur)} -> {hms(limit)}  "
                  f"({human(in_sz)} -> ~{human(est_out)})  {mp3.name}")
            cut += 1
            continue
        tmp = mp3.with_suffix(".mp3.cut.tmp")
        r = subprocess.run(
            ["ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error",
             "-i", str(mp3), "-c", "copy", "-t", str(limit),
             "-f", "mp3", "-y", str(tmp)],
        )
        valid = (
            r.returncode == 0
            and tmp.exists()
            and tmp.stat().st_size > 0
            and ffprobe_audio_ok(tmp)
        )
        if valid:
            discard(mp3, hard)
            tmp.rename(mp3)
            out_sz = mp3.stat().st_size
            bytes_in += in_sz
            bytes_out += out_sz
            cut += 1
            print(f"CAP   {hms(dur)} -> {hms(limit)}  "
                  f"({human(in_sz)} -> {human(out_sz)})  {mp3.name}")
        else:
            if tmp.exists():
                tmp.unlink()
            failed += 1
            print(f"FAIL  {mp3}")
    freed = bytes_in - bytes_out
    verb = "would free" if dry else "freed"
    print(f"\ncapped: {cut}  short: {short}  failed: {failed}  {verb}: {human(freed)}\n")
    return failed


# ---------- stage 4: rename ----------

def _is_emoji(ch: str) -> bool:
    if unicodedata.category(ch).startswith("S"):
        return True
    cp = ord(ch)
    for lo, hi in [
        (0x1F000, 0x1FAFF), (0x2600, 0x27BF), (0xFE00, 0xFE0F),
        (0x1F1E6, 0x1F1FF), (0x200D, 0x200D),
    ]:
        if lo <= cp <= hi:
            return True
    return False


def clean_stem(stem: str, max_chars: int) -> str:
    stem = re.sub(r"\s*\[[^\]]*\]\s*$", "", stem)
    stem = "".join(c for c in stem if not _is_emoji(c))
    stem = "".join(c for c in stem if not c.isdigit())
    stem = unicodedata.normalize("NFKD", stem).lower()
    stem = re.sub(r"[^a-z\s]+", " ", stem)
    words = [w for w in stem.split() if w]
    if not words:
        return ""
    result = words[0][:max_chars]
    for w in words[1:]:
        cand = result + "_" + w
        if len(cand) <= max_chars:
            result = cand
        else:
            break
    return result


def stage_rename(root: Path, max_chars: int, exts: set[str], dry: bool) -> int:
    print("=" * 60)
    print("STAGE 4: rename")
    print("=" * 60)
    renamed = coll = already = empty = failed = 0
    for path in iter_files(root, exts):
        new_stem = clean_stem(path.stem, max_chars)
        if not new_stem:
            empty += 1
            print(f"SKIP  (empty)  {path.name}")
            continue
        ext = path.suffix.lstrip(".").lower()
        new_path = path.with_name(f"{new_stem}.{ext}")
        if new_path == path:
            already += 1
            continue
        if new_path.exists():
            i = 2
            while True:
                cand = path.with_name(f"{new_stem}_{i}.{ext}")
                if not cand.exists():
                    new_path = cand
                    break
                i += 1
            coll += 1
        if dry:
            renamed += 1
            print(f"WOULD REN   {path.name}  ->  {new_path.name}")
        else:
            try:
                path.rename(new_path)
                renamed += 1
                print(f"REN         {path.name}  ->  {new_path.name}")
            except OSError as e:
                failed += 1
                print(f"FAIL  {path.name}: {e}", file=sys.stderr)
    print(f"\nrenamed: {renamed}  already-clean: {already}  "
          f"collisions: {coll}  empty: {empty}  failed: {failed}\n")
    return failed


# ---------- stage 5: cleanup webm originals ----------

def stage_cleanup(root: Path, dry: bool, hard: bool) -> int:
    print("=" * 60)
    print("STAGE 5: trash .webm originals whose .mp3 sibling is valid")
    print("=" * 60)
    gone = no_mp3 = bad_mp3 = failed = 0
    freed = 0
    for webm in iter_files(root, {"webm"}):
        mp3 = webm.with_suffix(".mp3")
        if not mp3.exists():
            no_mp3 += 1
            continue
        if mp3.stat().st_size == 0 or not ffprobe_audio_ok(mp3):
            bad_mp3 += 1
            print(f"SKIP  (mp3 invalid)  {webm.name}")
            continue
        sz = webm.stat().st_size
        if dry:
            gone += 1
            freed += sz
            print(f"WOULD TRASH  {human(sz)}  {webm.name}")
            continue
        try:
            discard(webm, hard)
            gone += 1
            freed += sz
            print(f"{'DEL' if hard else 'TRASH'}  {human(sz)}  {webm.name}")
        except subprocess.CalledProcessError as e:
            failed += 1
            print(f"FAIL  {webm.name}: {e}", file=sys.stderr)
    verb = "would free" if dry else "freed"
    print(f"\n{'would-trash' if dry else 'trashed'}: {gone}  "
          f"no-mp3: {no_mp3}  bad-mp3: {bad_mp3}  failed: {failed}  "
          f"{verb}: {human(freed)}\n")
    return failed


# ---------- main ----------

def main() -> int:
    p = argparse.ArgumentParser(
        description=__doc__,
        formatter_class=argparse.RawDescriptionHelpFormatter,
    )
    p.add_argument("root", nargs="?", default=None,
                   help="directory to scan (default: script's directory)")
    p.add_argument("--yes", "-y", action="store_true",
                   help="actually execute (default is dry run)")
    p.add_argument("--hard", action="store_true",
                   help="use rm instead of trash-put for discarded files")
    p.add_argument("--bitrate", default=DEFAULT_BITRATE,
                   help=f"mp3 bitrate for convert stage (default {DEFAULT_BITRATE})")
    p.add_argument("--limit", type=int, default=DEFAULT_LIMIT_SEC,
                   help=f"max mp3 duration in seconds (default {DEFAULT_LIMIT_SEC})")
    p.add_argument("--max-chars", type=int, default=DEFAULT_MAX_CHARS,
                   help=f"rename char cap, word-boundary (default {DEFAULT_MAX_CHARS})")
    p.add_argument("--ext", default=DEFAULT_RENAME_EXTS,
                   help=f"extensions for rename stage (default {DEFAULT_RENAME_EXTS})")
    p.add_argument("--skip-parts", action="store_true")
    p.add_argument("--skip-convert", action="store_true")
    p.add_argument("--skip-cap", action="store_true")
    p.add_argument("--skip-rename", action="store_true")
    p.add_argument("--skip-cleanup", action="store_true")
    args = p.parse_args()

    root = Path(args.root).resolve() if args.root else Path(__file__).resolve().parent
    if not root.is_dir():
        print(f"Not a directory: {root}", file=sys.stderr)
        return 2

    for tool in ("ffmpeg", "ffprobe"):
        if shutil.which(tool) is None:
            print(f"{tool} not found", file=sys.stderr)
            return 2
    uses_trash = args.yes and not args.hard and not (args.skip_parts and args.skip_cap and args.skip_cleanup)
    if uses_trash and shutil.which("trash-put") is None:
        print("trash-put not found — install trash-cli or pass --hard", file=sys.stderr)
        return 2

    dry = not args.yes
    exts = {e.strip().lower().lstrip(".") for e in args.ext.split(",") if e.strip()}

    print(f"Root:      {root}")
    print(f"Mode:      {'EXECUTE' if args.yes else 'DRY RUN (re-run with --yes)'}")
    print(f"Discard:   {'rm (permanent)' if args.hard else 'trash-put (recoverable)'}")
    print(f"Excluding: directories named {sorted(EXCLUDE_DIRS)}")
    print()

    total_failed = 0
    if not args.skip_parts:
        total_failed += stage_parts(root, dry, args.hard)
    if not args.skip_convert:
        total_failed += stage_convert(root, args.bitrate, dry)
    if not args.skip_cap:
        total_failed += stage_cap(root, args.limit, dry, args.hard)
    if not args.skip_rename:
        total_failed += stage_rename(root, args.max_chars, exts, dry)
    if not args.skip_cleanup:
        total_failed += stage_cleanup(root, dry, args.hard)

    print("=" * 60)
    print(f"DONE  (failures: {total_failed})")
    print("=" * 60)
    return 0 if total_failed == 0 else 1


if __name__ == "__main__":
    sys.exit(main())
